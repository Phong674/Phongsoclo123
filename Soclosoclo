    local function updateESP()
        for _, v in ipairs(espObjects) do v:Destroy() end
        for _, v in ipairs(espNameLabels) do v:Destroy() end
        espObjects = {}
        espNameLabels = {}
        if not espEnabled then return end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player then
                local char = p.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local esp = Instance.new("BoxHandleAdornment")
                    esp.Adornee = char.HumanoidRootPart
                    esp.Size = Vector3.new(4, 6, 4)
                    esp.Color3 = Color3.fromRGB(255, 0, 0)
                    esp.AlwaysOnTop = true
                    esp.ZIndex = 10
                    esp.Transparency = 0.5
                    esp.Parent = char.HumanoidRootPart
                    table.insert(espObjects, esp)
                    
                    local label = Instance.new("BillboardGui")
                    label.Parent = char.HumanoidRootPart
                    label.Size = UDim2.new(0, 200, 0, 40)
                    label.AlwaysOnTop = true
                    label.Adornee = char.HumanoidRootPart
                    local text = Instance.new("TextLabel")
                    text.Parent = label
                    text.Size = UDim2.new(1, 0, 1, 0)
                    text.BackgroundTransparency = 1
                    text.Text = p.Name
                    text.TextColor3 = Color3.fromRGB(255, 255, 0)
                    text.TextScaled = true
                    text.Font = Enum.Font.GothamBold
                    table.insert(espNameLabels, label)
                end
            end
        end
    end
